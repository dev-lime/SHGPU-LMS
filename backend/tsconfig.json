{
	"compilerOptions": {
		"module": "node16",
		"moduleResolution": "node16",
		"declaration": true,
		"removeComments": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"target": "es2017",
		"sourceMap": true,
		"outDir": "./dist",
		"baseUrl": "./",
		"incremental": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	}
}